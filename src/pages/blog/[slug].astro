---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BotaoWhatsApp from '../../components/BotaoWhatsApp.astro';
import IconeWhatsApp from '../../components/IconeWhatsApp.astro';
import { linkWhatsApp } from '../../lib/contato';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id } }));
}

const { slug } = Astro.params;
const post = await getEntry('blog', slug!);

if (!post) {
  return Astro.redirect('/blog');
}

const { Content } = await render(post);

function formatarData(date: Date) {
  return date.toLocaleDateString('pt-BR', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
  });
}
---

<Base
  title={`${post.data.title} · Mariana Gouvêa Psicóloga`}
  description={post.data.description}
>
  <Header />
  <main class="post-pagina">
    <article>
      <header class="post-pagina__header">
        <div class="container">
          <a href="/blog" class="post-pagina__voltar">← Voltar ao blog</a>
          {
            post.data.tags && post.data.tags.length > 0 && (
              <div class="post-pagina__tags">
                {post.data.tags.map((tag) => (
                  <span class="post-pagina__tag">{tag}</span>
                ))}
              </div>
            )
          }
          <h1 class="post-pagina__titulo">{post.data.title}</h1>
          <p class="post-pagina__descricao">{post.data.description}</p>
          <div class="post-pagina__meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {formatarData(post.data.pubDate)}
            </time>
            {
              post.data.updatedDate && (
                <span>
                  · Atualizado em{' '}
                  <time datetime={post.data.updatedDate.toISOString()}>
                    {formatarData(post.data.updatedDate)}
                  </time>
                </span>
              )
            }
          </div>
        </div>
      </header>

      {
        post.data.heroImage && (
          <div class="container">
            <img
              src={`${post.data.heroImage}-capa.webp`}
              alt={post.data.heroImageAlt ?? post.data.title}
              width={1280}
              height={720}
              class="post-pagina__capa"
              loading="eager"
            />
          </div>
        )
      }

      <div class="container post-pagina__corpo">
        <div class="prose">
          <Content />
        </div>

        <aside class="post-pagina__cta">
          <div class="post-pagina__cta-card">
            <p class="post-pagina__cta-titulo">
              Quer conversar sobre a saúde mental do seu filho(a)?
            </p>
            <p>Entre em contato — juntos, podemos entender o que ele ou ela precisa.</p>
            <a
              href={linkWhatsApp('Olá, Mariana! Li o seu blog e gostaria de conversar.')}
              class="btn btn--whatsapp"
              target="_blank"
              rel="noopener noreferrer"
            >
              <IconeWhatsApp />
              Falar no WhatsApp
            </a>
          </div>
        </aside>
      </div>
    </article>
  </main>
  <Footer />
  <BotaoWhatsApp />
</Base>

<style>
  .post-pagina {
    padding-top: 72px;
  }

  .post-pagina__header {
    background: linear-gradient(135deg, #f0f5e8 0%, var(--cor-fundo) 100%);
    padding-block: var(--espacamento-lg);
    border-bottom: 1px solid rgba(78, 111, 76, 0.1);
  }

  .post-pagina__voltar {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--cor-verde-escuro);
    font-weight: 500;
    margin-bottom: var(--espacamento-sm);
    opacity: 0.75;
    transition: opacity var(--transicao);
  }

  .post-pagina__voltar:hover {
    opacity: 1;
  }

  .post-pagina__tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .post-pagina__tag {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--cor-verde-escuro);
    background-color: var(--cor-verde-claro);
    padding: 0.2rem 0.6rem;
    border-radius: var(--raio-full);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .post-pagina__titulo {
    font-size: clamp(1.6rem, 4vw, 2.5rem);
    margin-bottom: 0.75rem;
  }

  .post-pagina__descricao {
    font-size: 1.1rem;
    color: var(--cor-texto);
    opacity: 0.75;
    max-width: 60ch;
    margin-bottom: 1rem;
  }

  .post-pagina__meta {
    font-size: 0.85rem;
    color: var(--cor-texto);
    opacity: 0.5;
  }

  .post-pagina__capa {
    width: 100%;
    max-width: 920px;
    margin: var(--espacamento-lg) auto 0;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--raio-lg);
    box-shadow: 0 16px 48px rgba(78, 111, 76, 0.18);
    display: block;
  }

  .post-pagina__corpo {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--espacamento-lg);
    align-items: start;
    padding-block: var(--espacamento-lg);
  }

  /* Tipografia do conteúdo Markdown */
  .prose {
    max-width: 680px;
  }

  .prose :global(h2) {
    font-size: 1.4rem;
    margin-top: 2em;
    margin-bottom: 0.6em;
  }

  .prose :global(h3) {
    font-size: 1.15rem;
    margin-top: 1.6em;
    margin-bottom: 0.5em;
  }

  .prose :global(p) {
    margin-bottom: 1.1em;
    line-height: 1.8;
    max-width: none;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.1em;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.4em;
    line-height: 1.7;
  }

  .prose :global(ul) {
    list-style: disc;
  }
  .prose :global(ol) {
    list-style: decimal;
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--cor-verde-claro);
    padding-left: 1.25rem;
    margin: 1.5em 0;
    color: var(--cor-verde-escuro);
    font-style: italic;
  }

  .prose :global(a) {
    color: var(--cor-verde-escuro);
    text-decoration: underline;
  }

  .prose :global(strong) {
    font-weight: 600;
    color: var(--cor-verde-escuro);
  }

  /* CTA lateral */
  .post-pagina__cta {
    position: sticky;
    top: calc(72px + 1.5rem);
  }

  .post-pagina__cta-card {
    background-color: #f5f8f0;
    border-radius: var(--raio-lg);
    padding: var(--espacamento-md);
    border: 1px solid rgba(78, 111, 76, 0.12);
    display: flex;
    flex-direction: column;
    gap: var(--espacamento-sm);
  }

  .post-pagina__cta-titulo {
    font-weight: 700;
    color: var(--cor-verde-escuro);
    font-size: 1rem;
    max-width: none;
  }

  .post-pagina__cta-card p:not(.post-pagina__cta-titulo) {
    font-size: 0.9rem;
    color: var(--cor-texto);
    opacity: 0.8;
    max-width: none;
  }

  @media (max-width: 900px) {
    .post-pagina__corpo {
      grid-template-columns: 1fr;
    }

    .post-pagina__cta {
      position: static;
    }
  }
</style>
