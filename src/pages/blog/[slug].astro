---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BotaoWhatsApp from '../../components/BotaoWhatsApp.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = await getEntry('blog', slug!);

if (!post) {
  return Astro.redirect('/blog');
}

const { Content } = await post.render();

function formatarData(date: Date) {
  return date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
}
---

<Base title={`${post.data.title} · Mariana Gouvêa Psicóloga`} description={post.data.description}>
  <Header />
  <main class="post-pagina">
    <article>
      <header class="post-pagina__header">
        <div class="container">
          <a href="/blog" class="post-pagina__voltar">← Voltar ao blog</a>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="post-pagina__tags">
              {post.data.tags.map(tag => (
                <span class="post-pagina__tag">{tag}</span>
              ))}
            </div>
          )}
          <h1 class="post-pagina__titulo">{post.data.title}</h1>
          <p class="post-pagina__descricao">{post.data.description}</p>
          <div class="post-pagina__meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {formatarData(post.data.pubDate)}
            </time>
            {post.data.updatedDate && (
              <span>· Atualizado em <time datetime={post.data.updatedDate.toISOString()}>{formatarData(post.data.updatedDate)}</time></span>
            )}
          </div>
        </div>
      </header>

      {post.data.heroImage && (
        <div class="container">
          <img
            src={`${post.data.heroImage}-capa.webp`}
            alt={post.data.heroImageAlt ?? post.data.title}
            width={1280}
            height={720}
            class="post-pagina__capa"
            loading="eager"
          />
        </div>
      )}

      <div class="container post-pagina__corpo">
        <div class="prose">
          <Content />
        </div>

        <aside class="post-pagina__cta">
          <div class="post-pagina__cta-card">
            <p class="post-pagina__cta-titulo">Quer conversar sobre a saúde mental do seu filho(a)?</p>
            <p>Entre em contato — juntos, podemos entender o que ele ou ela precisa.</p>
            <a
              href={`https://wa.me/818058508505?text=${encodeURIComponent('Olá, Mariana! Li o seu blog e gostaria de conversar.')}`}
              class="btn btn--whatsapp"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Falar no WhatsApp
            </a>
          </div>
        </aside>
      </div>
    </article>
  </main>
  <Footer />
  <BotaoWhatsApp />
</Base>

<style>
  .post-pagina {
    padding-top: 72px;
  }

  .post-pagina__header {
    background: linear-gradient(135deg, #f0f5e8 0%, var(--cor-fundo) 100%);
    padding-block: var(--espacamento-lg);
    border-bottom: 1px solid rgba(78, 111, 76, 0.1);
  }

  .post-pagina__voltar {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--cor-verde-escuro);
    font-weight: 500;
    margin-bottom: var(--espacamento-sm);
    opacity: 0.75;
    transition: opacity var(--transicao);
  }

  .post-pagina__voltar:hover { opacity: 1; }

  .post-pagina__tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .post-pagina__tag {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--cor-verde-escuro);
    background-color: var(--cor-verde-claro);
    padding: 0.2rem 0.6rem;
    border-radius: var(--raio-full);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .post-pagina__titulo {
    font-size: clamp(1.6rem, 4vw, 2.5rem);
    margin-bottom: 0.75rem;
  }

  .post-pagina__descricao {
    font-size: 1.1rem;
    color: var(--cor-texto);
    opacity: 0.75;
    max-width: 60ch;
    margin-bottom: 1rem;
  }

  .post-pagina__meta {
    font-size: 0.85rem;
    color: var(--cor-texto);
    opacity: 0.5;
  }

  .post-pagina__capa {
    width: 100%;
    max-width: 920px;
    margin: var(--espacamento-lg) auto 0;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--raio-lg);
    box-shadow: 0 16px 48px rgba(78, 111, 76, 0.18);
    display: block;
  }

  .post-pagina__corpo {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--espacamento-lg);
    align-items: start;
    padding-block: var(--espacamento-lg);
  }

  /* Tipografia do conteúdo Markdown */
  .prose {
    max-width: 680px;
  }

  .prose :global(h2) {
    font-size: 1.4rem;
    margin-top: 2em;
    margin-bottom: 0.6em;
  }

  .prose :global(h3) {
    font-size: 1.15rem;
    margin-top: 1.6em;
    margin-bottom: 0.5em;
  }

  .prose :global(p) {
    margin-bottom: 1.1em;
    line-height: 1.8;
    max-width: none;
  }

  .prose :global(ul), .prose :global(ol) {
    margin-bottom: 1.1em;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.4em;
    line-height: 1.7;
  }

  .prose :global(ul) { list-style: disc; }
  .prose :global(ol) { list-style: decimal; }

  .prose :global(blockquote) {
    border-left: 4px solid var(--cor-verde-claro);
    padding-left: 1.25rem;
    margin: 1.5em 0;
    color: var(--cor-verde-escuro);
    font-style: italic;
  }

  .prose :global(a) {
    color: var(--cor-verde-escuro);
    text-decoration: underline;
  }

  .prose :global(strong) {
    font-weight: 600;
    color: var(--cor-verde-escuro);
  }

  /* CTA lateral */
  .post-pagina__cta {
    position: sticky;
    top: calc(72px + 1.5rem);
  }

  .post-pagina__cta-card {
    background-color: #f5f8f0;
    border-radius: var(--raio-lg);
    padding: var(--espacamento-md);
    border: 1px solid rgba(78, 111, 76, 0.12);
    display: flex;
    flex-direction: column;
    gap: var(--espacamento-sm);
  }

  .post-pagina__cta-titulo {
    font-weight: 700;
    color: var(--cor-verde-escuro);
    font-size: 1rem;
    max-width: none;
  }

  .post-pagina__cta-card p:not(.post-pagina__cta-titulo) {
    font-size: 0.9rem;
    color: var(--cor-texto);
    opacity: 0.8;
    max-width: none;
  }

  @media (max-width: 900px) {
    .post-pagina__corpo {
      grid-template-columns: 1fr;
    }

    .post-pagina__cta {
      position: static;
    }
  }
</style>
