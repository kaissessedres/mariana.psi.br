---
import IconeWhatsApp from './IconeWhatsApp.astro';
import { linkWhatsApp } from '../lib/contato';
---

<a
  href={linkWhatsApp()}
  class="botao-whatsapp"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Falar com Mariana no WhatsApp"
  title="Falar no WhatsApp"
>
  <IconeWhatsApp size={28} />
  <span class="botao-whatsapp__label">Falar no WhatsApp</span>
</a>

<style>
  .botao-whatsapp {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 200;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background-color: var(--cor-rosa);
    color: #fff;
    border-radius: var(--raio-full);
    padding: 0.85rem 1.25rem;
    box-shadow: 0 4px 20px rgba(199, 102, 121, 0.45);
    font-weight: 600;
    font-size: 0.9rem;
    font-family: var(--fonte-base);
    transition:
      transform var(--transicao),
      box-shadow var(--transicao);
    text-decoration: none;
  }

  .botao-whatsapp:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 8px 28px rgba(199, 102, 121, 0.5);
  }

  .botao-whatsapp:active {
    transform: translateY(0) scale(1);
  }

  /* No desktop: mostrar só ícone; no mobile: ícone + label */
  .botao-whatsapp__label {
    display: none;
  }

  @media (max-width: 768px) {
    .botao-whatsapp__label {
      display: inline;
    }
  }
</style>
