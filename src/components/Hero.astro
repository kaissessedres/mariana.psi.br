---
import { Image } from 'astro:assets';
import fotoHero from '../assets/fotos/hero.jpg';

const WA_LINK = `https://wa.me/{{WHATSAPP}}?text=${encodeURIComponent('Olá, Mariana! Vim pelo site e gostaria de agendar uma conversa.')}`;
---

<section class="hero" id="inicio">
  <div class="hero__blob" aria-hidden="true">
    <svg viewBox="0 0 600 600" xmlns="http://www.w3.org/2000/svg">
      <path d="M300,50 C420,50 530,140 550,260 C570,380 490,490 370,530 C250,570 130,500 80,390 C30,280 70,140 160,90 C210,65 255,50 300,50Z" fill="var(--cor-verde-claro)" opacity="0.4"/>
    </svg>
  </div>
  <div class="hero__blob hero__blob--2" aria-hidden="true">
    <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
      <ellipse cx="200" cy="200" rx="180" ry="160" fill="var(--cor-rosa)" opacity="0.12"/>
    </svg>
  </div>

  <div class="container hero__inner">
    <div class="hero__conteudo">
      <p class="hero__pre-titulo">Psicóloga Infantojuvenil · CRP 07/41781</p>
      <h1 class="hero__titulo">Mariana Gouvêa</h1>
      <p class="hero__frase-valor">
        Cuidando da saúde mental de crianças e adolescentes, onde quer que vocês estejam — atendimento 100% online.
      </p>
      <div class="hero__acoes">
        <a href={WA_LINK} class="btn btn--whatsapp hero__btn" target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Agendar uma conversa
        </a>
        <a href="#sobre" class="btn btn--outline">
          Conheça meu trabalho
        </a>
      </div>
    </div>

    <div class="hero__visual">
      <div class="hero__foto-wrapper">
        <div class="hero__foto-blob" aria-hidden="true"></div>
        <Image
          src={fotoHero}
          alt="Mariana Gouvêa, psicóloga infantojuvenil, sentada em poltrona com xícara da marca e livros ao fundo"
          width={520}
          height={580}
          quality={82}
          class="hero__foto"
          loading="eager"
        />
      </div>
    </div>
  </div>

  <div class="hero__onda" aria-hidden="true">
    <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80Z" fill="var(--cor-fundo)"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: linear-gradient(135deg, #f0f5e8 0%, var(--cor-fundo) 60%);
    padding-top: calc(72px + var(--espacamento-lg));
    padding-bottom: var(--espacamento-xl);
    overflow: hidden;
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero__blob {
    position: absolute;
    pointer-events: none;
    top: -10%;
    right: -8%;
    width: 55%;
    max-width: 500px;
    opacity: 0.7;
  }

  .hero__blob--2 {
    top: auto;
    right: auto;
    bottom: 10%;
    left: -5%;
    width: 30%;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--espacamento-lg);
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero__conteudo {
    display: flex;
    flex-direction: column;
    gap: var(--espacamento-sm);
  }

  .hero__pre-titulo {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--cor-verde-escuro);
    opacity: 0.8;
    letter-spacing: 0.03em;
  }

  .hero__titulo {
    color: var(--cor-verde-escuro);
    margin-bottom: 0.25rem;
  }

  .hero__frase-valor {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--cor-texto);
    max-width: 50ch;
    line-height: 1.65;
  }

  .hero__acoes {
    display: flex;
    flex-wrap: wrap;
    gap: var(--espacamento-sm);
    margin-top: var(--espacamento-sm);
  }

  .hero__btn {
    font-size: 1rem;
    padding: 0.85rem 1.75rem;
  }

  /* Foto */
  .hero__visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__foto-wrapper {
    position: relative;
  }

  .hero__foto-blob {
    position: absolute;
    inset: -24px -20px -20px -20px;
    border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%;
    background: linear-gradient(135deg, var(--cor-verde-claro) 0%, rgba(193,209,138,0.4) 100%);
    z-index: 0;
  }

  .hero__foto {
    position: relative;
    z-index: 1;
    border-radius: 55% 45% 50% 50% / 45% 55% 45% 55%;
    width: 100%;
    max-width: 460px;
    height: auto;
    object-fit: cover;
    aspect-ratio: 4/5;
    display: block;
    box-shadow: 0 24px 60px rgba(78, 111, 76, 0.2);
  }

  .hero__onda {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    line-height: 0;
  }

  .hero__onda svg {
    width: 100%;
  }

  @media (max-width: 900px) {
    .hero {
      min-height: auto;
      padding-bottom: var(--espacamento-lg);
    }

    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero__frase-valor {
      margin-inline: auto;
    }

    .hero__acoes {
      justify-content: center;
    }

    .hero__visual {
      order: -1;
    }

    .hero__foto {
      max-width: 280px;
      margin-inline: auto;
    }
  }
</style>
