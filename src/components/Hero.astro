---
import IconeWhatsApp from './IconeWhatsApp.astro';
import { linkWhatsApp } from '../lib/contato';

const WA_LINK = linkWhatsApp();
---

<section class="hero" id="inicio">
  <div class="hero__blob" aria-hidden="true">
    <svg viewBox="0 0 600 600" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M300,50 C420,50 530,140 550,260 C570,380 490,490 370,530 C250,570 130,500 80,390 C30,280 70,140 160,90 C210,65 255,50 300,50Z"
        fill="var(--cor-verde-claro)"
        opacity="0.4"></path>
    </svg>
  </div>
  <div class="hero__blob hero__blob--2" aria-hidden="true">
    <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
      <ellipse cx="200" cy="200" rx="180" ry="160" fill="var(--cor-rosa)" opacity="0.12"
      ></ellipse>
    </svg>
  </div>

  <div class="container hero__inner">
    <div class="hero__conteudo">
      <p class="hero__pre-titulo">Psicóloga Infantojuvenil · CRP 07/41781</p>
      <h1 class="hero__titulo">Mariana Gouvêa</h1>
      <p class="hero__frase-valor">
        Cuidando da saúde mental de crianças e adolescentes, onde quer que vocês estejam —
        atendimento 100% online.
      </p>
      <div class="hero__acoes">
        <a
          href={WA_LINK}
          class="btn btn--whatsapp hero__btn"
          target="_blank"
          rel="noopener noreferrer"
        >
          <IconeWhatsApp size={20} />
          Agendar uma conversa
        </a>
        <a href="#sobre" class="btn btn--outline"> Conheça meu trabalho </a>
      </div>
    </div>

    <div class="hero__visual">
      <div class="hero__foto-wrapper">
        <div class="hero__foto-blob" aria-hidden="true"></div>
        <img
          src="/fotos-web/hero@1x.webp"
          srcset="/fotos-web/hero@1x.webp 1x, /fotos-web/hero@2x.webp 2x"
          alt="Mariana Gouvêa, psicóloga infantojuvenil, sorrindo enquanto segura bonecos do Divertidamente que representam as emoções"
          width={480}
          height={600}
          class="hero__foto"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>

  <div class="hero__onda" aria-hidden="true">
    <svg
      viewBox="0 0 1440 80"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="none"
    >
      <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80Z" fill="var(--cor-fundo)"
      ></path>
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: linear-gradient(135deg, #f0f5e8 0%, var(--cor-fundo) 60%);
    padding-top: calc(72px + var(--espacamento-lg));
    padding-bottom: var(--espacamento-xl);
    overflow: hidden;
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero__blob {
    position: absolute;
    pointer-events: none;
    top: -10%;
    right: -8%;
    width: 55%;
    max-width: 500px;
    opacity: 0.7;
  }

  .hero__blob--2 {
    top: auto;
    right: auto;
    bottom: 10%;
    left: -5%;
    width: 30%;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--espacamento-lg);
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero__conteudo {
    display: flex;
    flex-direction: column;
    gap: var(--espacamento-sm);
  }

  .hero__pre-titulo {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--cor-verde-escuro);
    opacity: 0.8;
    letter-spacing: 0.03em;
  }

  .hero__titulo {
    color: var(--cor-verde-escuro);
    margin-bottom: 0.25rem;
  }

  .hero__frase-valor {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--cor-texto);
    max-width: 50ch;
    line-height: 1.65;
  }

  .hero__acoes {
    display: flex;
    flex-wrap: wrap;
    gap: var(--espacamento-sm);
    margin-top: var(--espacamento-sm);
  }

  .hero__btn {
    font-size: 1rem;
    padding: 0.85rem 1.75rem;
  }

  /* Foto */
  .hero__visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__foto-wrapper {
    position: relative;
  }

  .hero__foto-blob {
    position: absolute;
    inset: -24px -20px -20px -20px;
    border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%;
    background: linear-gradient(
      135deg,
      var(--cor-verde-claro) 0%,
      rgba(193, 209, 138, 0.4) 100%
    );
    z-index: 0;
  }

  .hero__foto {
    position: relative;
    z-index: 1;
    border-radius: 55% 45% 50% 50% / 45% 55% 45% 55%;
    width: 100%;
    max-width: 460px;
    height: auto;
    object-fit: cover;
    aspect-ratio: 4/5;
    display: block;
    box-shadow: 0 24px 60px rgba(78, 111, 76, 0.2);
  }

  .hero__onda {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    line-height: 0;
  }

  .hero__onda svg {
    width: 100%;
  }

  @media (max-width: 900px) {
    .hero {
      min-height: auto;
      padding-bottom: var(--espacamento-lg);
    }

    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero__frase-valor {
      margin-inline: auto;
    }

    .hero__acoes {
      justify-content: center;
    }

    .hero__visual {
      order: -1;
    }

    .hero__foto {
      max-width: 280px;
      margin-inline: auto;
    }
  }
</style>
