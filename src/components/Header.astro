---
const WA_LINK = `https://wa.me/818058508505?text=${encodeURIComponent('Olá, Mariana! Vim pelo site e gostaria de agendar uma conversa.')}`;
---

<header class="header" id="header">
  <div class="container header__inner">
    <a href="/" class="header__logo" aria-label="Mariana Gouvêa Psicóloga — Página inicial">
      <img src="/simbolo.png" alt="" class="header__simbolo" aria-hidden="true" />
      <span class="header__logo-texto">
        <strong>Mariana Gouvêa</strong>
        <small>Psicóloga infantojuvenil</small>
      </span>
    </a>

    <nav class="header__nav" aria-label="Navegação principal">
      <ul class="header__nav-list">
        <li><a href="/#sobre">Sobre</a></li>
        <li><a href="/#atendimentos">Atendimentos</a></li>
        <li><a href="/#duvidas">Dúvidas</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/#contato">Contato</a></li>
      </ul>
    </nav>

    <a href={WA_LINK} class="btn btn--whatsapp header__cta" target="_blank" rel="noopener noreferrer">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      WhatsApp
    </a>

    <button class="header__hamburguer" id="hamburguer" aria-label="Abrir menu" aria-expanded="false" aria-controls="nav-mobile">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile nav -->
  <div class="header__nav-mobile" id="nav-mobile" aria-hidden="true">
    <ul>
      <li><a href="/#sobre" class="nav-mobile__link">Sobre</a></li>
      <li><a href="/#atendimentos" class="nav-mobile__link">Atendimentos</a></li>
      <li><a href="/#duvidas" class="nav-mobile__link">Dúvidas</a></li>
      <li><a href="/blog" class="nav-mobile__link">Blog</a></li>
      <li><a href="/#contato" class="nav-mobile__link">Contato</a></li>
      <li>
        <a href={WA_LINK} class="btn btn--whatsapp" target="_blank" rel="noopener noreferrer" style="width:100%;justify-content:center;">
          WhatsApp
        </a>
      </li>
    </ul>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: var(--cor-fundo);
    border-bottom: 1px solid rgba(78, 111, 76, 0.1);
    transition: box-shadow var(--transicao);
  }

  .header.scrolled {
    box-shadow: 0 2px 16px rgba(46, 58, 45, 0.08);
  }

  .header__inner {
    display: flex;
    align-items: center;
    gap: var(--espacamento-md);
    height: 72px;
  }

  .header__logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .header__simbolo {
    height: 44px;
    width: auto;
  }

  .header__logo-texto {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .header__logo-texto strong {
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--cor-verde-escuro);
  }

  .header__logo-texto small {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--cor-texto);
    opacity: 0.7;
    letter-spacing: 0.01em;
  }

  .header__nav {
    flex: 1;
  }

  .header__nav-list {
    display: flex;
    gap: var(--espacamento-md);
    justify-content: center;
  }

  .header__nav-list a {
    font-weight: 500;
    color: var(--cor-texto);
    transition: color var(--transicao);
    font-size: 0.95rem;
  }

  .header__nav-list a:hover {
    color: var(--cor-verde-escuro);
  }

  .header__cta {
    flex-shrink: 0;
    font-size: 0.9rem;
    padding: 0.6rem 1.2rem;
  }

  .header__hamburguer {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    margin-left: auto;
  }

  .header__hamburguer span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--cor-verde-escuro);
    border-radius: 2px;
    transition: transform var(--transicao), opacity var(--transicao);
  }

  .header__hamburguer[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .header__hamburguer[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }

  .header__hamburguer[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .header__nav-mobile {
    display: none;
    background-color: var(--cor-fundo);
    border-top: 1px solid rgba(78, 111, 76, 0.1);
    padding: var(--espacamento-md);
  }

  .header__nav-mobile ul {
    display: flex;
    flex-direction: column;
    gap: var(--espacamento-sm);
  }

  .nav-mobile__link {
    font-weight: 500;
    font-size: 1.1rem;
    color: var(--cor-texto);
    display: block;
    padding: 0.25rem 0;
  }

  @media (max-width: 768px) {
    .header__nav,
    .header__cta {
      display: none;
    }

    .header__hamburguer {
      display: flex;
    }

    .header__nav-mobile.aberto {
      display: block;
    }
  }
</style>

<script>
  const hamburguer = document.getElementById('hamburguer');
  const navMobile = document.getElementById('nav-mobile');
  const header = document.getElementById('header');

  hamburguer?.addEventListener('click', () => {
    const aberto = hamburguer.getAttribute('aria-expanded') === 'true';
    hamburguer.setAttribute('aria-expanded', String(!aberto));
    navMobile?.classList.toggle('aberto');
    navMobile?.setAttribute('aria-hidden', String(aberto));
  });

  // Fechar menu ao clicar em link
  navMobile?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      hamburguer?.setAttribute('aria-expanded', 'false');
      navMobile.classList.remove('aberto');
      navMobile.setAttribute('aria-hidden', 'true');
    });
  });

  // Sombra no scroll
  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 10);
  });
</script>
