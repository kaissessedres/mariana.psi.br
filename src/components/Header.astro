---
import IconeWhatsApp from './IconeWhatsApp.astro';
import { linkWhatsApp } from '../lib/contato';

const WA_LINK = linkWhatsApp();
---

<header class="header" id="header">
  <div class="container header__inner">
    <a
      href="/"
      class="header__logo"
      aria-label="Mariana Gouvêa Psicóloga — Página inicial"
    >
      <img src="/simbolo.png" alt="" class="header__simbolo" aria-hidden="true" />
      <span class="header__logo-texto">
        <strong>Mariana Gouvêa</strong>
        <small>Psicóloga infantojuvenil</small>
      </span>
    </a>

    <nav class="header__nav" aria-label="Navegação principal">
      <ul class="header__nav-list">
        <li><a href="/#sobre">Sobre</a></li>
        <li><a href="/#atendimentos">Atendimentos</a></li>
        <li><a href="/#duvidas">Dúvidas</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/#contato">Contato</a></li>
      </ul>
    </nav>

    <a
      href={WA_LINK}
      class="btn btn--whatsapp header__cta"
      target="_blank"
      rel="noopener noreferrer"
    >
      <IconeWhatsApp />
      WhatsApp
    </a>

    <button
      class="header__hamburguer"
      id="hamburguer"
      aria-label="Abrir menu"
      aria-expanded="false"
      aria-controls="nav-mobile"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile nav -->
  <div class="header__nav-mobile" id="nav-mobile" aria-hidden="true">
    <ul>
      <li><a href="/#sobre" class="nav-mobile__link">Sobre</a></li>
      <li><a href="/#atendimentos" class="nav-mobile__link">Atendimentos</a></li>
      <li><a href="/#duvidas" class="nav-mobile__link">Dúvidas</a></li>
      <li><a href="/blog" class="nav-mobile__link">Blog</a></li>
      <li><a href="/#contato" class="nav-mobile__link">Contato</a></li>
      <li>
        <a
          href={WA_LINK}
          class="btn btn--whatsapp"
          target="_blank"
          rel="noopener noreferrer"
          style="width:100%;justify-content:center;"
        >
          WhatsApp
        </a>
      </li>
    </ul>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: var(--cor-fundo);
    border-bottom: 1px solid rgba(78, 111, 76, 0.1);
    transition: box-shadow var(--transicao);
  }

  .header.scrolled {
    box-shadow: 0 2px 16px rgba(46, 58, 45, 0.08);
  }

  .header__inner {
    display: flex;
    align-items: center;
    gap: var(--espacamento-md);
    height: 72px;
  }

  .header__logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .header__simbolo {
    height: 44px;
    width: auto;
  }

  .header__logo-texto {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .header__logo-texto strong {
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--cor-verde-escuro);
  }

  .header__logo-texto small {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--cor-texto);
    opacity: 0.7;
    letter-spacing: 0.01em;
  }

  .header__nav {
    flex: 1;
  }

  .header__nav-list {
    display: flex;
    gap: var(--espacamento-md);
    justify-content: center;
  }

  .header__nav-list a {
    font-weight: 500;
    color: var(--cor-texto);
    transition: color var(--transicao);
    font-size: 0.95rem;
  }

  .header__nav-list a:hover {
    color: var(--cor-verde-escuro);
  }

  .header__cta {
    flex-shrink: 0;
    font-size: 0.9rem;
    padding: 0.6rem 1.2rem;
  }

  .header__hamburguer {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    margin-left: auto;
  }

  .header__hamburguer span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--cor-verde-escuro);
    border-radius: 2px;
    transition:
      transform var(--transicao),
      opacity var(--transicao);
  }

  .header__hamburguer[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .header__hamburguer[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }

  .header__hamburguer[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .header__nav-mobile {
    display: none;
    background-color: var(--cor-fundo);
    border-top: 1px solid rgba(78, 111, 76, 0.1);
    padding: var(--espacamento-md);
  }

  .header__nav-mobile ul {
    display: flex;
    flex-direction: column;
    gap: var(--espacamento-sm);
  }

  .nav-mobile__link {
    font-weight: 500;
    font-size: 1.1rem;
    color: var(--cor-texto);
    display: block;
    padding: 0.25rem 0;
  }

  @media (max-width: 768px) {
    .header__nav,
    .header__cta {
      display: none;
    }

    .header__hamburguer {
      display: flex;
    }

    .header__nav-mobile.aberto {
      display: block;
    }
  }
</style>

<script>
  const hamburguer = document.getElementById('hamburguer');
  const navMobile = document.getElementById('nav-mobile');
  const header = document.getElementById('header');

  hamburguer?.addEventListener('click', () => {
    const aberto = hamburguer.getAttribute('aria-expanded') === 'true';
    hamburguer.setAttribute('aria-expanded', String(!aberto));
    navMobile?.classList.toggle('aberto');
    navMobile?.setAttribute('aria-hidden', String(aberto));
  });

  // Fechar menu ao clicar em link
  navMobile?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      hamburguer?.setAttribute('aria-expanded', 'false');
      navMobile.classList.remove('aberto');
      navMobile.setAttribute('aria-hidden', 'true');
    });
  });

  // Sombra no scroll
  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 10);
  });
</script>
