---
import Blob from './Blob.astro';
import IconeWhatsApp from './IconeWhatsApp.astro';
import { linkWhatsApp } from '../lib/contato';

const WA_LINK = linkWhatsApp();

const passos = [
  {
    numero: '01',
    cor: 'verde',
    icone: '💬',
    titulo: 'Primeiro contato',
    texto:
      'Você me chama no WhatsApp e conta, sem compromisso, o que está acontecendo e o que está buscando.',
  },
  {
    numero: '02',
    cor: 'rosa',
    icone: '🤝',
    titulo: 'Conversa inicial',
    texto:
      'Marcamos uma conversa para entender, juntos, a necessidade do seu filho(a) e como o acompanhamento pode ajudar.',
  },
  {
    numero: '03',
    cor: 'laranja',
    icone: '🗓️',
    titulo: 'Agendamento',
    texto:
      'Definimos os horários e a frequência que melhor se encaixam na rotina de vocês — tudo online.',
  },
  {
    numero: '04',
    cor: 'verde',
    icone: '🌱',
    titulo: 'Acompanhamento',
    texto:
      'Começamos o processo terapêutico, com você por perto e um cuidado pensado para cada fase.',
  },
];
---

<section class="secao como-funciona tem-blob" id="como-funciona">
  <Blob
    cor="var(--cor-verde-claro)"
    variante={2}
    size="300px"
    top="-90px"
    right="8%"
    opacity={0.2}
    duration="15s"
  />
  <Blob
    cor="var(--cor-rosa)"
    variante={3}
    size="220px"
    top="50%"
    left="-70px"
    opacity={0.1}
    delay="2s"
    duration="13s"
  />
  <div class="container">
    <div class="como-funciona__cabecalho reveal">
      <h2>Como funciona</h2>
      <p>
        Dar o primeiro passo é mais simples do que parece. Veja como começamos juntos.
      </p>
    </div>

    <ol class="como-funciona__passos reveal-group">
      {
        passos.map((p) => (
          <li class={`passo passo--${p.cor}`}>
            <div class="passo__topo">
              <span class="passo__numero">{p.numero}</span>
              <span class="passo__icone" aria-hidden="true">
                {p.icone}
              </span>
            </div>
            <h3 class="passo__titulo">{p.titulo}</h3>
            <p class="passo__texto">{p.texto}</p>
          </li>
        ))
      }
    </ol>

    <div class="como-funciona__cta reveal">
      <a
        href={WA_LINK}
        class="btn btn--whatsapp"
        target="_blank"
        rel="noopener noreferrer"
      >
        <IconeWhatsApp />
        Dar o primeiro passo
      </a>
    </div>
  </div>
</section>

<style>
  .como-funciona {
    background-color: var(--cor-fundo);
  }

  .como-funciona__cabecalho {
    text-align: center;
    margin-bottom: var(--espacamento-lg);
  }

  .como-funciona__cabecalho p {
    margin-inline: auto;
    font-size: 1.05rem;
    color: var(--cor-texto);
    opacity: 0.8;
    margin-top: 0.5rem;
  }

  .como-funciona__passos {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--espacamento-md);
    counter-reset: passo;
    position: relative;
  }

  .passo {
    background-color: #fff;
    border-radius: var(--raio-lg);
    padding: var(--espacamento-md);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    box-shadow: 0 4px 20px rgba(78, 111, 76, 0.08);
    position: relative;
    transition:
      transform var(--transicao),
      box-shadow var(--transicao);
  }

  .passo:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 32px rgba(78, 111, 76, 0.14);
  }

  .passo__topo {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .passo__numero {
    font-size: 2.2rem;
    font-weight: 700;
    line-height: 1;
    opacity: 0.9;
  }

  .passo--verde .passo__numero {
    color: var(--cor-verde-escuro);
  }
  .passo--rosa .passo__numero {
    color: var(--cor-rosa);
  }
  .passo--laranja .passo__numero {
    color: var(--cor-laranja);
  }

  .passo__icone {
    font-size: 1.6rem;
  }

  .passo__titulo {
    font-size: 1.1rem;
    color: var(--cor-verde-escuro);
  }

  .passo__texto {
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--cor-texto);
    opacity: 0.85;
    max-width: none;
  }

  /* Linha conectora entre os passos (desktop) */
  .passo::after {
    content: '';
    position: absolute;
    top: 50%;
    right: calc(var(--espacamento-md) * -1);
    width: var(--espacamento-md);
    height: 2px;
    background: repeating-linear-gradient(
      90deg,
      var(--cor-verde-claro) 0 6px,
      transparent 6px 12px
    );
    z-index: 1;
  }

  .passo:last-child::after {
    display: none;
  }

  .como-funciona__cta {
    text-align: center;
    margin-top: var(--espacamento-lg);
  }

  @media (max-width: 900px) {
    .como-funciona__passos {
      grid-template-columns: repeat(2, 1fr);
    }
    .passo:nth-child(2)::after {
      display: none;
    }
  }

  @media (max-width: 560px) {
    .como-funciona__passos {
      grid-template-columns: 1fr;
    }
    .passo::after {
      display: none;
    }
  }
</style>
