---
import { Image } from 'astro:assets';
import fotoAdolescentes from '../assets/fotos/atend-adolescentes.jpg';
import fotoGrupo from '../assets/fotos/atend-grupo.jpg';
import fotoParental from '../assets/fotos/atend-parental.jpg';

const atendimentos = [
  {
    foto: fotoAdolescentes,
    fotoAlt: 'Mariana e adolescente jogando UNO — representando a terapia com recursos lúdicos',
    icone: '🧑‍💻',
    titulo: 'Psicoterapia para Adolescentes',
    subtitulo: 'Online',
    texto: `Na psicoterapia para adolescentes também é utilizada a abordagem da Terapia Cognitivo-Comportamental, buscando identificar e modificar padrões disfuncionais de pensamento e comportamento, que geram sofrimento psicológico em diversas esferas da vida do adolescente. Para isso, também são utilizadas técnicas e recursos lúdicos, como jogos, filmes, músicas, animes, entre outros, que fazem sentido para o adolescente e que auxiliam no processo terapêutico.`,
    cor: 'verde',
  },
  {
    foto: fotoGrupo,
    fotoAlt: 'Mariana brincando com bolhas com duas crianças — representando o trabalho em grupo',
    icone: '👥',
    titulo: 'Grupo de Adolescentes',
    subtitulo: 'Online',
    texto: `Os grupos de adolescentes ocorrem na abordagem da Terapia Cognitivo-Comportamental, possuindo uma estrutura e duração definidas, que varia de acordo com o objetivo terapêutico. São utilizados para promoção e prevenção da saúde mental, sintomas depressivos, ansiedade, autoestima, criação de laços, entre outros.`,
    cor: 'rosa',
  },
  {
    foto: fotoParental,
    fotoAlt: 'Mariana interagindo com bebê em atividade lúdica — representando a orientação parental',
    icone: '🤝',
    titulo: 'Orientação Parental',
    subtitulo: 'Individual ou em grupo · Online',
    texto: `Orientação para pais e cuidadores sobre cuidados em saúde mental, estratégias de regulação emocional para seus filhos, bem como orientações de manejo, entre outras. A orientação parental pode ser realizada com a família e atua como um suporte para os pais ou cuidadores, que muitas vezes não sabem o que fazer durante o desenvolvimento de seus filhos.`,
    cor: 'laranja',
  },
];
---

<section class="secao atendimentos" id="atendimentos">
  <div class="container">
    <div class="atendimentos__cabecalho">
      <h2>Atendimentos</h2>
      <p>Todos os atendimentos são realizados online, com segurança e acolhimento.</p>
    </div>

    <ul class="atendimentos__grid">
      {atendimentos.map(a => (
        <li class={`card card--${a.cor}`}>
          <div class="card__foto-wrapper">
            <Image
              src={a.foto}
              alt={a.fotoAlt}
              width={400}
              height={240}
              quality={80}
              class="card__foto"
              loading="lazy"
            />
            <span class={`card__selo card__selo--${a.cor}`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="3" width="20" height="14" rx="2"/>
                <line x1="8" y1="21" x2="16" y2="21"/>
                <line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
              {a.subtitulo}
            </span>
          </div>
          <div class="card__conteudo">
            <h3 class="card__titulo">{a.titulo}</h3>
            <p class="card__texto">{a.texto}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .atendimentos {
    background-color: var(--cor-fundo);
  }

  .atendimentos__cabecalho {
    text-align: center;
    margin-bottom: var(--espacamento-lg);
  }

  .atendimentos__cabecalho p {
    margin-inline: auto;
    font-size: 1.05rem;
    color: var(--cor-texto);
    opacity: 0.8;
    margin-top: 0.5rem;
  }

  .atendimentos__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--espacamento-md);
  }

  .card {
    background-color: #fff;
    border-radius: var(--raio-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 20px rgba(78, 111, 76, 0.08);
    transition: transform var(--transicao), box-shadow var(--transicao);
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(78, 111, 76, 0.14);
  }

  /* Foto do card */
  .card__foto-wrapper {
    position: relative;
    overflow: hidden;
  }

  .card__foto {
    width: 100%;
    height: 220px;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.4s ease;
  }

  .card:hover .card__foto {
    transform: scale(1.04);
  }

  .card__selo {
    position: absolute;
    bottom: 0.75rem;
    left: 0.75rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.7rem;
    border-radius: var(--raio-full);
    backdrop-filter: blur(4px);
  }

  .card__selo--verde {
    color: var(--cor-verde-escuro);
    background-color: rgba(193, 209, 138, 0.92);
  }

  .card__selo--rosa {
    color: #fff;
    background-color: rgba(199, 102, 121, 0.9);
  }

  .card__selo--laranja {
    color: #fff;
    background-color: rgba(206, 130, 54, 0.9);
  }

  .card__conteudo {
    padding: var(--espacamento-md);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .card__titulo {
    color: var(--cor-verde-escuro);
    font-size: 1.1rem;
  }

  .card__texto {
    font-size: 0.92rem;
    line-height: 1.75;
    color: var(--cor-texto);
    max-width: none;
    opacity: 0.85;
  }

  /* Borda superior colorida */
  .card--verde { border-top: 4px solid var(--cor-verde-escuro); }
  .card--rosa  { border-top: 4px solid var(--cor-rosa); }
  .card--laranja { border-top: 4px solid var(--cor-laranja); }

  @media (max-width: 900px) {
    .atendimentos__grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin-inline: auto;
    }
  }
</style>
