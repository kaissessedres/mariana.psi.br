---
import Blob from './Blob.astro';

const WA_LINK = `https://wa.me/818058508505?text=${encodeURIComponent('Olá, Mariana! Vim pelo site e gostaria de agendar uma conversa.')}`;
---

<section class="secao cta-final" id="contato">
  <!-- Onda decorativa topo -->
  <div class="cta-final__onda cta-final__onda--topo" aria-hidden="true">
    <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,40 C360,0 1080,80 1440,40 L1440,0 L0,0Z" fill="var(--cor-fundo)"/>
    </svg>
  </div>

  <!-- Blobs orgânicos (consistentes com o resto da página) -->
  <Blob cor="#ffffff" variante={1} size="380px" top="12%" right="6%" opacity={0.06} duration="17s" />
  <Blob cor="var(--cor-verde-claro)" variante={3} size="200px" bottom="14%" right="20%" opacity={0.1} delay="2s" duration="14s" />
  <Blob cor="#ffffff" variante={2} size="160px" top="24%" right="-30px" opacity={0.05} delay="1s" duration="15s" />

  <div class="container cta-final__inner">
    <div class="cta-final__conteudo reveal">
      <p class="cta-final__pre">Próximo passo</p>
      <h2 class="cta-final__titulo">Mas então, do que o meu filho(a) precisa?</h2>
      <p class="cta-final__texto">
        Vamos conversar? E então poderemos ver juntos do que o seu filho(a) precisa!
      </p>
      <div class="cta-final__acoes">
        <a href={WA_LINK} class="btn btn--cta" target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Falar com a Mariana no WhatsApp
        </a>
        <a href="mailto:marianagouvea.psi@gmail.com" class="cta-final__email">
          ou envie um e-mail →
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-final {
    background: linear-gradient(135deg, var(--cor-verde-escuro) 0%, #3a5238 100%);
    color: #fff;
    position: relative;
    overflow: hidden;
    padding-top: var(--espacamento-xl);
  }

  .cta-final__onda {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    line-height: 0;
  }

  .cta-final__onda svg {
    width: 100%;
  }

  .cta-final__inner {
    position: relative;
    z-index: 1;
  }

  .cta-final__conteudo {
    display: flex;
    flex-direction: column;
    gap: var(--espacamento-sm);
    max-width: 760px;
  }

  .cta-final__pre {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--cor-verde-claro);
    opacity: 0.9;
  }

  .cta-final__titulo {
    color: #fff;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
  }

  .cta-final__texto {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.65;
    max-width: 50ch;
  }

  .cta-final__acoes {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--espacamento-md);
    margin-top: var(--espacamento-sm);
  }

  .btn--cta {
    background-color: #fff;
    color: var(--cor-verde-escuro);
    font-size: 1.05rem;
    padding: 1rem 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  .btn--cta:hover {
    background-color: var(--cor-verde-claro);
  }

  .cta-final__email {
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.95rem;
    font-weight: 500;
    transition: color var(--transicao);
  }

  .cta-final__email:hover {
    color: #fff;
  }

  @media (max-width: 768px) {
    .cta-final__inner {
      text-align: center;
    }

    .cta-final__conteudo {
      align-items: center;
    }

    .cta-final__texto {
      margin-inline: auto;
    }

    .cta-final__acoes {
      justify-content: center;
      flex-direction: column;
    }
  }
</style>
