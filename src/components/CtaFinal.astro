---
import Blob from './Blob.astro';
import IconeWhatsApp from './IconeWhatsApp.astro';
import { linkWhatsApp, linkEmail } from '../lib/contato';

const WA_LINK = linkWhatsApp();
---

<section class="secao cta-final" id="contato">
  <!-- Onda decorativa topo -->
  <div class="cta-final__onda cta-final__onda--topo" aria-hidden="true">
    <svg
      viewBox="0 0 1440 80"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="none"
    >
      <path d="M0,40 C360,0 1080,80 1440,40 L1440,0 L0,0Z" fill="var(--cor-fundo)"></path>
    </svg>
  </div>

  <!-- Blobs orgânicos (consistentes com o resto da página) -->
  <Blob
    cor="#ffffff"
    variante={1}
    size="380px"
    top="12%"
    right="6%"
    opacity={0.06}
    duration="17s"
  />
  <Blob
    cor="var(--cor-verde-claro)"
    variante={3}
    size="200px"
    bottom="14%"
    right="20%"
    opacity={0.1}
    delay="2s"
    duration="14s"
  />
  <Blob
    cor="#ffffff"
    variante={2}
    size="160px"
    top="24%"
    right="-30px"
    opacity={0.05}
    delay="1s"
    duration="15s"
  />

  <div class="container cta-final__inner">
    <div class="cta-final__conteudo reveal">
      <p class="cta-final__pre">Próximo passo</p>
      <h2 class="cta-final__titulo">Mas então, do que o meu filho(a) precisa?</h2>
      <p class="cta-final__texto">
        Vamos conversar? E então poderemos ver juntos do que o seu filho(a) precisa!
      </p>
      <div class="cta-final__acoes">
        <a href={WA_LINK} class="btn btn--cta" target="_blank" rel="noopener noreferrer">
          <IconeWhatsApp size={22} />
          Falar com a Mariana no WhatsApp
        </a>
        <a href={linkEmail()} class="cta-final__email"> ou envie um e-mail → </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-final {
    background: linear-gradient(135deg, var(--cor-verde-escuro) 0%, #3a5238 100%);
    color: #fff;
    position: relative;
    overflow: hidden;
    padding-top: var(--espacamento-xl);
  }

  .cta-final__onda {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    line-height: 0;
  }

  .cta-final__onda svg {
    width: 100%;
  }

  .cta-final__inner {
    position: relative;
    z-index: 1;
  }

  .cta-final__conteudo {
    display: flex;
    flex-direction: column;
    gap: var(--espacamento-sm);
    max-width: 760px;
  }

  .cta-final__pre {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--cor-verde-claro);
    opacity: 0.9;
  }

  .cta-final__titulo {
    color: #fff;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
  }

  .cta-final__texto {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.65;
    max-width: 50ch;
  }

  .cta-final__acoes {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--espacamento-md);
    margin-top: var(--espacamento-sm);
  }

  .btn--cta {
    background-color: #fff;
    color: var(--cor-verde-escuro);
    font-size: 1.05rem;
    padding: 1rem 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  .btn--cta:hover {
    background-color: var(--cor-verde-claro);
  }

  .cta-final__email {
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.95rem;
    font-weight: 500;
    transition: color var(--transicao);
  }

  .cta-final__email:hover {
    color: #fff;
  }

  @media (max-width: 768px) {
    .cta-final__inner {
      text-align: center;
    }

    .cta-final__conteudo {
      align-items: center;
    }

    .cta-final__texto {
      margin-inline: auto;
    }

    .cta-final__acoes {
      justify-content: center;
      flex-direction: column;
    }
  }
</style>
